# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Base de datos — Supabase (PostgreSQL)
# DATABASE_URL: usa la cadena "pooled" (puerto 6543, pgbouncer) para la app.
# DIRECT_URL: usa la cadena "direct" (puerto 5432) para migraciones Prisma.
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# ─────────────────────────────────────────────────────────────
# Supabase (Storage — se usa desde la Fase 4)
# SUPABASE_SERVICE_ROLE_KEY: ¡SOLO server-side! Nunca exponer al cliente.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=resumes

# ─────────────────────────────────────────────────────────────
# Autenticación — Clerk
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx
# Secret del webhook de Clerk (Dashboard > Webhooks). Necesario para sincronizar usuarios.
CLERK_WEBHOOK_SECRET=whsec_xxxx

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ─────────────────────────────────────────────────────────────
# IA — OpenAI (se usa desde la Fase 5)
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
AI_MODEL_EXTRACTION=gpt-4o-mini
AI_MODEL_EXPLANATION=gpt-4o-mini

# ─────────────────────────────────────────────────────────────
# Correo — Resend (para enviar citaciones a entrevista)
# Sin dominio verificado, Resend solo entrega a tu propio correo (modo prueba).
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM="Talento 360 <onboarding@resend.dev>"

# ─────────────────────────────────────────────────────────────
# Límites / seguridad (se usan desde la Fase 4)
# ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document
